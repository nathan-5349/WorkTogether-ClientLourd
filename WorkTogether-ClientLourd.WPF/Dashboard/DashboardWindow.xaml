<mah:MetroWindow x:Class="WorkTogether_ClientLourd.WPF.Dashboard.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        Title="WorkTogether - Dashboard" 
        Height="600" Width="1000"
        WindowStartupLocation="CenterScreen">
    <mah:MetroWindow.Resources>
        <Style x:Key="SidebarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,12"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3D5166"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </mah:MetroWindow.Resources>

    <!-- Racine = Grid avec 2 colonnes -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- COLONNE 0 : Sidebar -->
        <Border Grid.Column="0" Background="#2C3E50">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0">
                    <StackPanel Margin="10,20,10,20">
                        <TextBlock Text="WorkTogether" FontSize="16" FontWeight="Bold" Foreground="White" TextAlignment="Center"/>
                        <TextBlock x:Name="UserNameBlock" FontSize="12" Foreground="#BDC3C7" TextAlignment="Center" Margin="0,5,0,0"/>
                        <TextBlock x:Name="UserRoleBlock" FontSize="12" Foreground="#7F8C8D" TextAlignment="Center"/>
                    </StackPanel>
                    <Separator Background="#3D5166"/>
                    <StackPanel Margin="0,10,0,0">
                        <Button x:Name="BtnUsers" Content="Utilisateurs" Click="BtnUsers_Click" Style="{StaticResource SidebarButton}"/>
                        <Button x:Name="BtnBays" Content="Baies" Click="BtnBays_Click" Style="{StaticResource SidebarButton}"/>
                        <Button x:Name="BtnOffers" Content="Offres" Click="BtnOffers_Click" Style="{StaticResource SidebarButton}"/>
                        <Button x:Name="BtnCustomers" Content="Clients" Click="BtnCustomers_Click" Style="{StaticResource SidebarButton}"/>
                        <Button x:Name="BtnReservations" Content="Réservations" Click="BtnReservations_Click" Style="{StaticResource SidebarButton}"/>
                    </StackPanel>
                </StackPanel>
                <Button Grid.Row="1" Content="Déconnexion" Click="BtnLogout_Click" Style="{StaticResource SidebarButton}" Margin="0,0,0,15"/>
            </Grid>
        </Border>

        <!-- COLONNE 1 : Contenu principal -->
        <ContentControl x:Name="MainContent" Grid.Column="1" Margin="10"/>
    </Grid>
</mah:MetroWindow>