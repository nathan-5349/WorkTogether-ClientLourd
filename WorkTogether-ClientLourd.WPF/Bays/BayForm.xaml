<UserControl x:Class="WorkTogether_ClientLourd.WPF.Bays.BayForm"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls">
    <ScrollViewer>
        <StackPanel Margin="30" Background="{DynamicResource MahApps.Brushes.Window.Background}">
            <TextBlock x:Name="FormTitle" FontSize="22" FontWeight="Bold"
                       Margin="0,0,0,25"
                       Foreground="{DynamicResource MahApps.Brushes.AccentBase}"/>

            <TextBox x:Name="NameBox" Margin="0,0,0,15"
                     mah:TextBoxHelper.Watermark="Nom de la baie"
                     mah:TextBoxHelper.UseFloatingWatermark="True"
                     Style="{StaticResource MahApps.Styles.TextBox}"/>

            <TextBlock Text="Capacité en unités" Margin="0,0,0,5" 
            Foreground="{DynamicResource MahApps.Brushes.Text}"/>
            <mah:NumericUpDown x:Name="CapacityBox" Margin="0,0,0,15"
                   Minimum="1" Maximum="42"
                   Value="42"
                   HorizontalContentAlignment="Left"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button x:Name="BtnCancel" Content="Annuler"
                        Click="BtnCancel_Click" Margin="0,0,10,0"/>
                <Button x:Name="BtnSave" Content="Enregistrer"
                        Click="BtnSave_Click"
                        Background="{DynamicResource MahApps.Brushes.Accent}"
                        Foreground="White"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>