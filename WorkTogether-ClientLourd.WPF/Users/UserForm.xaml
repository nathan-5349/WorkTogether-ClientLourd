<UserControl x:Class="WorkTogether_ClientLourd.WPF.Users.UserForm"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls">
    <ScrollViewer>
        <StackPanel Margin="30" Background="{DynamicResource MahApps.Brushes.Window.Background}">
            <TextBlock x:Name="FormTitle" FontSize="22" FontWeight="Bold" 
                       Margin="0,0,0,25"
                       Foreground="{DynamicResource MahApps.Brushes.AccentBase}"/>

            <!-- Champs communs -->
            <TextBox x:Name="FirstNameBox" Margin="0,0,0,15"
                     mah:TextBoxHelper.Watermark="Prénom"
                     mah:TextBoxHelper.UseFloatingWatermark="True"
                     Style="{StaticResource MahApps.Styles.TextBox}"/>

            <TextBox x:Name="NameBox" Margin="0,0,0,15"
                     mah:TextBoxHelper.Watermark="Nom"
                     mah:TextBoxHelper.UseFloatingWatermark="True"
                     Style="{StaticResource MahApps.Styles.TextBox}"/>

            <TextBox x:Name="EmailBox" Margin="0,0,0,15"
                     mah:TextBoxHelper.Watermark="Email"
                     mah:TextBoxHelper.UseFloatingWatermark="True"
                     Style="{StaticResource MahApps.Styles.TextBox}"/>

            <PasswordBox x:Name="PasswordBox" Margin="0,0,0,5"
                         mah:TextBoxHelper.Watermark="Mot de passe"
                         mah:TextBoxHelper.UseFloatingWatermark="True"
                         Style="{StaticResource MahApps.Styles.PasswordBox}"/>
            <TextBlock x:Name="PasswordHint" 
                       Text="Laisser vide pour ne pas modifier" 
                       FontSize="11" Foreground="Gray" 
                       Margin="0,0,0,15"
                       Visibility="Collapsed"/>

            <!-- Champs Staff -->
            <StackPanel x:Name="StaffFields">
                <ComboBox x:Name="RoleBox" Margin="0,0,0,15"
                          mah:TextBoxHelper.Watermark="Rôle"
                          mah:TextBoxHelper.UseFloatingWatermark="True"
                          Style="{StaticResource MahApps.Styles.ComboBox}">
                    <ComboBoxItem Content="ROLE_ADMIN"/>
                    <ComboBoxItem Content="ROLE_ACCOUNTANT"/>
                    <ComboBoxItem Content="ROLE_SUPPORT"/>
                    <ComboBoxItem Content="ROLE_TECHNICIAN"/>
                </ComboBox>
            </StackPanel>

            <!-- Champs Client -->
            <StackPanel x:Name="ClientFields" Visibility="Collapsed">
                <TextBox x:Name="PhoneBox" Margin="0,0,0,15"
                         mah:TextBoxHelper.Watermark="Téléphone"
                         mah:TextBoxHelper.UseFloatingWatermark="True"
                         Style="{StaticResource MahApps.Styles.TextBox}"/>

                <TextBox x:Name="AdressBox" Margin="0,0,0,15"
                         mah:TextBoxHelper.Watermark="Adresse"
                         mah:TextBoxHelper.UseFloatingWatermark="True"
                         Style="{StaticResource MahApps.Styles.TextBox}"/>

                <TextBox x:Name="InvoiceAdressBox" Margin="0,0,0,15"
                         mah:TextBoxHelper.Watermark="Adresse de facturation"
                         mah:TextBoxHelper.UseFloatingWatermark="True"
                         Style="{StaticResource MahApps.Styles.TextBox}"/>

                <ComboBox x:Name="ClientTypeBox" Margin="0,0,0,15"
                          mah:TextBoxHelper.Watermark="Type de client"
                          mah:TextBoxHelper.UseFloatingWatermark="True"
                          Style="{StaticResource MahApps.Styles.ComboBox}"
                          SelectionChanged="ClientTypeBox_SelectionChanged">
                    <ComboBoxItem Content="Particulier" Tag="particular"/>
                    <ComboBoxItem Content="Entreprise" Tag="company"/>
                </ComboBox>

                <!-- Champs Particulier -->
                <StackPanel x:Name="ParticularFields">
                    <ComboBox x:Name="GenderBox" Margin="0,0,0,15"
                              mah:TextBoxHelper.Watermark="Genre"
                              mah:TextBoxHelper.UseFloatingWatermark="True"
                              Style="{StaticResource MahApps.Styles.ComboBox}">
                        <ComboBoxItem Content="Monsieur"/>
                        <ComboBoxItem Content="Madame"/>
                    </ComboBox>
                </StackPanel>

                <!-- Champs Entreprise -->
                <StackPanel x:Name="CompanyFields" Visibility="Collapsed">
                    <TextBox x:Name="SiretBox" Margin="0,0,0,15"
                             mah:TextBoxHelper.Watermark="SIRET"
                             mah:TextBoxHelper.UseFloatingWatermark="True"
                             Style="{StaticResource MahApps.Styles.TextBox}"/>
                    <TextBox x:Name="CompanyNameBox" Margin="0,0,0,15"
                             mah:TextBoxHelper.Watermark="Nom de l'entreprise"
                             mah:TextBoxHelper.UseFloatingWatermark="True"
                             Style="{StaticResource MahApps.Styles.TextBox}"/>
                </StackPanel>
            </StackPanel>

            <!-- Boutons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button x:Name="BtnCancel" Content="Annuler"
        Click="BtnCancel_Click" Margin="0,0,10,0"/>

                <Button x:Name="BtnSave" Content="Enregistrer"
        Click="BtnSave_Click"
        Background="{DynamicResource MahApps.Brushes.Accent}"
        Foreground="White"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>