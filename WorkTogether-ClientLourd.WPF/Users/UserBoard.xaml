<UserControl x:Class="WorkTogether_ClientLourd.WPF.Users.UserBoard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls">
    <Grid Background="{DynamicResource MahApps.Brushes.Window.Background}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Barre du haut : recherche + boutons -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBox x:Name="SearchBox" Width="200" Margin="0,0,10,0"
                     mah:TextBoxHelper.Watermark="Rechercher..."
                     TextChanged="SearchBox_TextChanged"/>
            <Button Content="Ajouter" Click="BtnAdd_Click" Margin="0,0,5,0"/>
            <Button Content="Modifier" Click="BtnEdit_Click" Margin="0,0,5,0"/>
            <Button Content="Supprimer" Click="BtnDelete_Click"/>
        </StackPanel>

        <!-- Liste des utilisateurs -->
        <DataGrid Grid.Row="1" x:Name="UserGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionChanged="UserGrid_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Prénom" Binding="{Binding FirstName}" Width="120"/>
                <DataGridTextColumn Header="Nom" Binding="{Binding Name}" Width="120"/>
                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="200"/>
                <DataGridTextColumn Header="Rôle" Binding="{Binding Roles}" Width="150"/>
                <DataGridTextColumn Header="Type" Binding="{Binding Discr}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
