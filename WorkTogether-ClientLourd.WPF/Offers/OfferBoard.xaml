<UserControl x:Class="WorkTogether_ClientLourd.WPF.Offers.OfferBoard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             Loaded="OfferBoard_Loaded">

    <UserControl.Resources>
        <Style x:Key="BtnActiveStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsActive}" Value="True">
                    <Setter Property="Background" Value="#2E7D32"/>
                    <Setter Property="Content" Value="✔ Actif"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsActive}" Value="False">
                    <Setter Property="Background" Value="#C62828"/>
                    <Setter Property="Content" Value="✘ Inactif"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="BtnInfoStyle" TargetType="Button">
            <Setter Property="Content" Value="ℹ Réservations"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#1565C0"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource MahApps.Brushes.Window.Background}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,10,0,10">
            <TextBox x:Name="SearchOfferBox" Width="200" Margin="0,0,10,0"
                     mah:TextBoxHelper.Watermark="Rechercher une offre..."
                     TextChanged="SearchOfferBox_TextChanged"/>

            <ComboBox x:Name="FilterStatus" Width="150" Margin="0,0,15,0" SelectedValuePath="Tag"
                      SelectedValue="active" SelectionChanged="FilterStatus_Changed">
                <ComboBoxItem Content="Actives uniquement" Tag="active"/>
                <ComboBoxItem Content="Inactives uniquement" Tag="inactive"/>
                <ComboBoxItem Content="Toutes" Tag="all"/>
            </ComboBox>

            <Button Content="Ajouter" Click="BtnAddOffer_Click" Margin="0,0,5,0"/>
            <Button Content="Modifier" Click="BtnEditOffer_Click" Margin="0,0,5,0"/>
            <Button Content="Supprimer" Click="BtnDeleteOffer_Click"/>
        </StackPanel>

        <DataGrid Grid.Row="1" x:Name="OfferGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionChanged="OfferGrid_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Nom" Binding="{Binding Name}" Width="200"/>
                <DataGridTextColumn Header="Unités" Binding="{Binding NbUnit}" Width="100"/>
                <DataGridTextColumn Header="Prix (€)" Binding="{Binding Price}" Width="100"/>
                <DataGridTextColumn Header="Version" Binding="{Binding Version}" Width="80"/>

                <DataGridTemplateColumn Header="Statut" Width="110">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource BtnActiveStyle}" 
                                    Tag="{Binding Id}"
                                    Click="BtnToggleActive_Click"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="" Width="130">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource BtnInfoStyle}"
                                    Tag="{Binding Id}"
                                    Click="BtnInfoOffer_Click"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>