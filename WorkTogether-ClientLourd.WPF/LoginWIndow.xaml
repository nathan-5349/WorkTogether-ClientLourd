<mah:MetroWindow x:Class="WorkTogether_ClientLourd.WPF.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        xmlns:local="clr-namespace:WorkTogether_ClientLourd.WPF"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Title="LoginWindow" Height="450" Width="800">
    <Grid Margin="20">
        <StackPanel VerticalAlignment="Center" >
            <TextBlock Text="Connexion" FontSize="22" FontWeight="Bold" Margin="0,0,0,20"/>
            <TextBox x:Name="EmailBox" mah:TextBoxHelper.Watermark="Email" Margin="0,0,0,10"/>
            <PasswordBox x:Name="PasswordBox" mah:TextBoxHelper.Watermark="Mot de passe" Margin="0,0,0,20" KeyDown="PasswordBox_KeyDown"/>
            <Button Name="LoginButton" Content="Se connecter" Click="LoginClick"/>
        </StackPanel>
    </Grid>
</mah:MetroWindow>
