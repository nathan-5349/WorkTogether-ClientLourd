<UserControl x:Class="WorkTogether_ClientLourd.WPF.Reservations.ReservationBoard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             Loaded="ReservationBoard_Loaded">

    <Grid Background="{DynamicResource MahApps.Brushes.Window.Background}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Barre de filtres -->
        <WrapPanel Grid.Row="0" Orientation="Horizontal" Margin="0,10,0,10">

            <!-- Recherche client -->
            <TextBox x:Name="SearchBox" Width="180" Margin="0,0,10,5"
                     mah:TextBoxHelper.Watermark="Rechercher un client..."
                     TextChanged="SearchBox_TextChanged"/>

            <!-- Filtre statut -->
            <ComboBox x:Name="FilterStatus" Width="150" Margin="0,0,10,5"
                      SelectedValuePath="Tag" SelectedValue="all"
                      SelectionChanged="FilterStatus_Changed">
                <ComboBoxItem Content="Tous statuts"   Tag="all"/>
                <ComboBoxItem Content="En attente"     Tag="En attente"/>
                <ComboBoxItem Content="Confirmée"      Tag="Confirmée"/>
                <ComboBoxItem Content="Annulée"        Tag="Annulée"/>
            </ComboBox>

            <!-- Filtre offre -->
            <ComboBox x:Name="FilterOffer" Width="170" Margin="0,0,10,5"
                      DisplayMemberPath="Name"
                      SelectedValuePath="Id"
                      SelectionChanged="FilterOffer_Changed"/>

            <!-- Filtre type client -->
            <ComboBox x:Name="FilterCustomerType" Width="150" Margin="0,0,10,5"
                      SelectedValuePath="Tag" SelectedValue="all"
                      SelectionChanged="FilterCustomerType_Changed">
                <ComboBoxItem Content="Tous clients"   Tag="all"/>
                <ComboBoxItem Content="Particuliers"   Tag="particular"/>
                <ComboBoxItem Content="Entreprises"    Tag="company"/>
            </ComboBox>

        </WrapPanel>

        <!-- Tableau des réservations -->
        <DataGrid Grid.Row="1" x:Name="ReservationGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  CanUserAddRows="False">
            <DataGrid.Columns>

                <DataGridTextColumn Header="ID"
                                    Binding="{Binding Id}"
                                    Width="50"/>

                <DataGridTextColumn Header="Client"
                                    Binding="{Binding CustomerFullName}"
                                    Width="*"/>

                <DataGridTextColumn Header="Type"
                                    Binding="{Binding CustomerType}"
                                    Width="90"/>

                <DataGridTemplateColumn Header="Offre" Width="140">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border CornerRadius="4" Margin="3"
                                    Background="{Binding OfferBackground}">
                                <TextBlock Text="{Binding OfferName}"
                                           Foreground="{Binding OfferForeground}"
                                           FontWeight="SemiBold"
                                           Padding="6,3"
                                           HorizontalAlignment="Center"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Début"
                                    Binding="{Binding BeginDateFormatted}"
                                    Width="100"/>

                <DataGridTextColumn Header="Fin"
                                    Binding="{Binding FinishDateFormatted}"
                                    Width="100"/>

                <DataGridTextColumn Header="Unités"
                                    Binding="{Binding UnitCount}"
                                    Width="70"/>

                <DataGridTemplateColumn Header="Statut" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border CornerRadius="4" Margin="3"
                                    Background="{Binding StatusBackground}">
                                <TextBlock Text="{Binding Status}"
                                           Foreground="{Binding StatusForeground}"
                                           FontWeight="SemiBold"
                                           Padding="6,3"
                                           HorizontalAlignment="Center"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
